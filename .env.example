# ─────────────────────────────────────────────────────────────
#  DV DOOZY  ·  Environment variables (production)
# ─────────────────────────────────────────────────────────────
# The app works WITHOUT these — it falls back to mock auth + an
# empty in-memory store. Configure these to go live.
# ─────────────────────────────────────────────────────────────

# Force mock mode (skip Firebase) — useful for offline dev demos
NEXT_PUBLIC_USE_MOCK=false

# ── Firebase (Web SDK) ───────────────────────────────────────
# Firebase Console → Project Settings → Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Comma-separated admin emails — these accounts get admin role on sign-in
NEXT_PUBLIC_ADMIN_EMAILS=Doozy@rook.com

# Seeded mock admin (only used when Firebase is disabled)
NEXT_PUBLIC_SEED_ADMIN_EMAIL=Doozy@rook.com
NEXT_PUBLIC_SEED_ADMIN_PASSWORD=Doozyadmin

# ── Cloudinary (unsigned uploads from the browser) ───────────
# 1. Cloudinary Console → Settings → Upload → Upload presets
# 2. Add upload preset → Signing mode: "Unsigned"
# 3. Optional: set a folder (e.g. "doozy") so all uploads are organized
# 4. Paste the cloud name + preset name below
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
# Optional folder (e.g. "doozy/products", "doozy/banners")
NEXT_PUBLIC_CLOUDINARY_FOLDER=doozy

# ── Razorpay (optional) ──────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
